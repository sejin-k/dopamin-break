{
    "manifest_version": 3,
    "name": "Dopamin Break - 사이트 접속 중독 방지",
    "version": "1.0",
    "description": "중독성 있는 사이트 접속 시 경고 모달을 띄워 중독을 방지합니다.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "tabs",
        "storage"
    ],
    "action": {
        "default_popup": "src/popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}